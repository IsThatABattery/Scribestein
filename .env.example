## Copy this file to .env and fill in your values

# Absolute path to your service account JSON credentials
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Speech v2 resource location (typically global)
GCP_LOCATION=global

# Recognizer resource ID to create/use
RECOGNIZER_ID=radio-stream-recognizer

# Live audio stream URL
STREAM_URL=https://broadcastify.cdnstream1.com/26933

# Language and model
LANGUAGE_CODE=en-US
MODEL=telephony

FIRESTORE_COLLECTION=
FIRESTORE_DATABASE=